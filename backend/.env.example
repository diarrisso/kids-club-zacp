APP_NAME="Kids Club by zacp"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Pin explicitly so the Laravel 13 prefix-hyphenation change cannot silently
# rotate the session cookie name on deploy (which would log users out).
SESSION_COOKIE=kidsclub_session
# Defaults to true outside local/testing; uncomment to force explicitly in prod.
# SESSION_SECURE_COOKIE=true

# Comma-separated origins allowed to call the widget API; wildcard by default.
# WIDGET_ALLOWED_ORIGINS=https://praxis-domain.de

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# Pinned so the Laravel 13 prefix-hyphenation change cannot rotate cache keys.
CACHE_PREFIX=kidsclub_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Pinned so the Laravel 13 prefix-hyphenation change cannot rotate redis keys.
REDIS_PREFIX=kidsclub_database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@masinga-booking.de"
MAIL_FROM_NAME="Masinga Booking"

# Cabinet inbox that receives operational alerts (e.g. an appointment was cancelled).
PRACTICE_NOTIFICATION_EMAIL="praxis@kidsclub.de"

# Initial admin password used by KidsClubSeeder. REQUIRED outside local/testing
# (seeding aborts if unset); local/testing fall back to a throwaway default.
KIDSCLUB_ADMIN_PASSWORD=

# Production: set MAIL_MAILER=postmark and provide the server token.
POSTMARK_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

APP_COUNTRY=Germany
APP_BUNDESLAND=NorthRhineWestphalia
